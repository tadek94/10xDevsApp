---
import Layout from "@/layouts/Layout.astro";
import { DeleteAccountForm } from "@/components/DeleteAccountForm";

const { user } = Astro.locals;
---

<Layout title="Ustawienia konta">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div
      class="w-full max-w-md rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl"
    >
      <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Ustawienia konta
      </h1>
      <p class="text-sm text-blue-100/70">
        Zalogowano jako <span class="font-semibold text-white">{user?.email}</span>
      </p>

      <div class="mt-8 rounded-xl border border-red-400/30 bg-red-500/10 p-6 text-left">
        <h2 class="mb-2 text-lg font-semibold text-red-200">Usuń konto</h2>
        <p class="mb-4 text-sm text-blue-100/70">
          Trwałe usunięcie konta kasuje wszystkie Twoje fiszki i historię powtórek. Tej operacji nie można cofnąć.
        </p>
        <DeleteAccountForm client:load />
      </div>

      <div class="mt-6">
        <a href="/dashboard" class="text-sm text-blue-200 underline-offset-4 hover:underline"> ← Powrót do panelu </a>
      </div>
    </div>
  </div>
</Layout>
