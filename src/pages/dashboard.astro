---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;
---

<Layout title="Dashboard">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-3xl rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <div class="text-center">
        <h1 class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Dashboard
        </h1>
        <p class="text-blue-100/80">
          Witaj, <span class="font-semibold text-white">{user?.email}</span>
        </p>
        <p class="mt-2 text-sm text-blue-100/50">Wybierz, od czego chcesz zacząć.</p>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <!-- Primary action: spans both columns and sits first to lead the eye -->
        <a
          href="/generate"
          class="group flex items-center gap-4 rounded-xl border border-purple-400/40 bg-purple-500/20 p-5 transition-colors hover:bg-purple-500/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-purple-300/60 sm:col-span-2"
        >
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-purple-500/30 text-purple-100">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <path
                d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"
              ></path>
              <path d="M20 2v4"></path>
              <path d="M22 4h-4"></path>
              <circle cx="4" cy="20" r="2"></circle>
            </svg>
          </span>
          <span class="min-w-0">
            <span class="block text-lg font-semibold text-purple-100">Generuj fiszki</span>
            <span class="block text-sm text-purple-100/70">Wklej tekst, a AI utworzy fiszki gotowe do nauki.</span>
          </span>
        </a>

        <a
          href="/flashcards"
          class="group flex items-center gap-3 rounded-xl border border-blue-400/40 bg-blue-500/20 p-4 transition-colors hover:bg-blue-500/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-300/60"
        >
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-blue-500/30 text-blue-100">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="m16 6 4 14"></path>
              <path d="M12 6v14"></path>
              <path d="M8 8v12"></path>
              <path d="M4 4v16"></path>
            </svg>
          </span>
          <span class="min-w-0">
            <span class="block font-semibold text-blue-100">Moja kolekcja</span>
            <span class="block text-sm text-blue-100/70">Przeglądaj, edytuj i usuwaj swoje karty.</span>
          </span>
        </a>

        <a
          href="/review"
          class="group flex items-center gap-3 rounded-xl border border-emerald-400/40 bg-emerald-500/20 p-4 transition-colors hover:bg-emerald-500/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300/60"
        >
          <span
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-emerald-500/30 text-emerald-100"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"></path>
              <path d="M21 3v5h-5"></path>
            </svg>
          </span>
          <span class="min-w-0">
            <span class="block font-semibold text-emerald-100">Sesja powtórek</span>
            <span class="block text-sm text-emerald-100/70">Powtarzaj karty metodą spaced repetition.</span>
          </span>
        </a>
      </div>

      <div class="mt-8 flex justify-center">
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            Sign out
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
