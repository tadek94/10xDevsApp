---
import Layout from "@/layouts/Layout.astro";
import { ReviewSession } from "@/components/flashcards/ReviewSession";
import { createClient } from "@/lib/supabase";
import { formatDate } from "@/lib/utils";
import type { ReviewCard } from "@/types";

export const prerender = false;

let initialCards: ReviewCard[] = [];

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase) {
  // Hydrate the session so the SELECT carries the user JWT — RLS returns only this user's cards.
  await supabase.auth.getSession();
  // Due cards in SRS order: srs_due <= now, ascending.
  const { data, error } = await supabase
    .from("flashcards")
    .select("id, front, back")
    .lte("srs_due", formatDate(new Date()))
    .order("srs_due", { ascending: true });
  if (error) {
    // Surface DB errors in logs instead of silently rendering an empty session.
    // eslint-disable-next-line no-console
    console.error(error);
  }
  initialCards = data ?? [];
}
---

<Layout title="Sesja powtórek — 10xCards">
  <div class="bg-cosmic min-h-screen py-8">
    <div class="mx-auto mb-4 flex w-full max-w-2xl items-center justify-between gap-2 px-4">
      <a
        href="/dashboard"
        class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-blue-100 transition-colors hover:bg-white/20"
      >
        ← Dashboard
      </a>
      <a
        href="/flashcards"
        class="rounded-lg border border-blue-400/40 bg-blue-500/20 px-4 py-2 text-sm font-medium text-blue-200 transition-colors hover:bg-blue-500/30"
      >
        Moja kolekcja
      </a>
    </div>
    <ReviewSession client:load initialCards={initialCards} />
  </div>
</Layout>
