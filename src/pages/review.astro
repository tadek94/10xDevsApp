---
import Layout from "@/layouts/Layout.astro";
import { ReviewSession } from "@/components/flashcards/ReviewSession";
import ScreenNav from "@/components/ScreenNav.astro";
import { createClient } from "@/lib/supabase";
import { formatDate } from "@/lib/utils";
import type { ReviewCard } from "@/types";

export const prerender = false;

let initialCards: ReviewCard[] = [];

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase) {
  // Hydrate the session so the SELECT carries the user JWT — RLS returns only this user's cards.
  await supabase.auth.getSession();
  // Due cards in SRS order: srs_due <= now, ascending.
  const { data, error } = await supabase
    .from("flashcards")
    .select("id, front, back")
    .lte("srs_due", formatDate(new Date()))
    .order("srs_due", { ascending: true });
  if (error) {
    // Surface DB errors in logs instead of silently rendering an empty session.
    // eslint-disable-next-line no-console
    console.error(error);
  }
  initialCards = data ?? [];
}
---

<Layout title="Sesja powtórek — 10xCards">
  <div class="bg-cosmic min-h-screen py-8">
    <ScreenNav current="review" />
    <ReviewSession client:load initialCards={initialCards} />
  </div>
</Layout>
