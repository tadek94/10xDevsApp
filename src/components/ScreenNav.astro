---
type Screen = "generate" | "flashcards" | "review";

interface Props {
  current: Screen;
}

const { current } = Astro.props;

// Full class strings per screen (no fragment interpolation — Tailwind JIT must see complete literals).
const screens: { id: Screen; href: string; label: string; class: string }[] = [
  {
    id: "generate",
    href: "/generate",
    label: "Generuj fiszki",
    class:
      "rounded-lg border border-purple-400/40 bg-purple-500/20 px-4 py-2 text-sm font-medium text-purple-200 transition-colors hover:bg-purple-500/30",
  },
  {
    id: "flashcards",
    href: "/flashcards",
    label: "Moja kolekcja",
    class:
      "rounded-lg border border-blue-400/40 bg-blue-500/20 px-4 py-2 text-sm font-medium text-blue-200 transition-colors hover:bg-blue-500/30",
  },
  {
    id: "review",
    href: "/review",
    label: "Sesja powtórek",
    class:
      "rounded-lg border border-emerald-400/40 bg-emerald-500/20 px-4 py-2 text-sm font-medium text-emerald-200 transition-colors hover:bg-emerald-500/30",
  },
];

const peers = screens.filter((s) => s.id !== current);
---

<div class="mx-auto mb-4 flex w-full max-w-2xl items-center justify-between gap-2 px-4">
  <a
    href="/dashboard"
    class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-blue-100 transition-colors hover:bg-white/20"
  >
    ← Dashboard
  </a>
  <div class="flex gap-2">
    {
      peers.map((s) => (
        <a href={s.href} class:list={s.class}>
          {s.label}
        </a>
      ))
    }
  </div>
</div>
