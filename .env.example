SUPABASE_URL=###
SUPABASE_KEY=###
# Supabase service-role key — full-privilege, server-only. Required for account deletion.
# Never commit a real value; add it to production by hand.
SUPABASE_SERVICE_ROLE_KEY=###
OPENROUTER_API_KEY=###
# Sentry client-side (public) DSN — inlined into the browser bundle at build time.
# Safe to expose; leave unset to disable client monitoring.
PUBLIC_SENTRY_DSN=###