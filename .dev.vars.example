SUPABASE_URL=###
SUPABASE_KEY=###
# Supabase service-role key — full-privilege, server-only. Required for account deletion.
# Never commit a real value; add it to production by hand.
SUPABASE_SERVICE_ROLE_KEY=###
OPENROUTER_API_KEY=###
# Sentry server-side DSN (Worker runtime). Leave unset to disable monitoring.
# In prod, set as a Cloudflare secret by hand — do not commit a real value.
SENTRY_DSN=###
